          },
          recoveryPerRest: {
            "": "Modifiers removed per rest",
            "@Tooltip": "Integer value for how many penalties to remove each time a player passes the night in bed.",
          },
          maximumHealthPenaltyMultiplier: {
            "": "Overcast Maximum Healthy Penalty Multiplier",
            "@Tooltip": "Each modifier subtracts this value from maximum health.",
